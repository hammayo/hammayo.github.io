    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.4.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "pagefind": "^1.5.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
