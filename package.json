{
  "name": "hammayo-portfolio",
  "version": "1.0.9",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --turbopack",
    "build": "node scripts/copy-blog-assets.mjs && next build && bunx pagefind --site out --output-subdir pagefind",
    "start": "next start",
    "serve": "npx serve out -c $(pwd)/serve.json",
    "lint": "eslint src",
    "lint:strict": "eslint --max-warnings=0 src",
    "lint:fix": "eslint src --fix && prettier --write src",
    "type-check": "tsc --noEmit"
  },
